# designbridge.io (apps/web) — copy to .env.local and fill in. All values are optional for a local
# build (the app degrades to "auth not configured" + in-memory store), but required in production.

# Supabase Auth (magic-link). Public values — safe in the browser bundle.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Persistence. Use postgres + the SAME database as the relay so keys minted here are exactly the
# rows the relay validates (docs/DECISIONS.md D6). Defaults to an ephemeral in-memory store.
WEB_STORE=memory
DATABASE_URL=

# Public URLs surfaced in the dashboard pairing helper + docs snippets.
NEXT_PUBLIC_RELAY_URL=http://localhost:8080
NEXT_PUBLIC_SITE_URL=http://localhost:3000
