{
  "name": "designbridge",
  "version": "0.5.0",
  "private": true,
  "description": "One-click import of AI-generated designs (Claude Design) into editable Figma layers.",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "node scripts/dev-stack.mjs",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "test": "pnpm run build && pnpm -r test && pnpm run test:capture && pnpm run test:plugin",
    "test:capture": "node test/run-capture-tests.js packages/capture-core/dist/content.js test/fixtures/golden-1.html",
    "test:plugin": "node test/run-plugin-tests.js packages/figma-builder/dist/code.js packages/capture-core/dist/content.js test/fixtures/golden-1.html"
  },
  "devDependencies": {
    "@designbridge/app-mcp": "workspace:*",
    "@designbridge/app-relay": "workspace:*",
    "@designbridge/app-worker": "workspace:*",
    "@eslint/js": "^9.28.0",
    "@types/node": "^22.15.29",
    "eslint": "^9.28.0",
    "esbuild": "^0.25.5",
    "globals": "^15.15.0",
    "playwright": "^1.52.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.0",
    "vitest": "^3.2.1",
    "zod": "^3.25.56"
  }
}
